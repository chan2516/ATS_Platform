# Copy to .env and adjust (Spring Boot reads these as environment variables)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/ats
SPRING_DATASOURCE_USERNAME=ats
SPRING_DATASOURCE_PASSWORD=ats
SERVER_PORT=8080
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# HS256 signing key: at least 32 bytes. Generate a strong secret for production.
JWT_SECRET=
# Optional; default 86400000 (24h)
# JWT_EXPIRATION_MS=86400000

# Phase 3: resume files (default ./data/resumes under the process working directory)
# RESUME_STORAGE_ROOT=D:/path/to/resume-storage
# Optional max upload size in bytes (default 5242880)
# RESUME_MAX_BYTES=5242880
